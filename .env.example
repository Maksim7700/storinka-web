# ─────────────────────────────────────────────────────────────
# Storinka Frontend — env variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Spring Boot API the Next.js rewrite proxies /api/* to (server-side fetches).
BACKEND_URL=http://localhost:8080

# ─── Google OAuth ───────────────────────────────────────────
# Same value as backend's GOOGLE_CLIENT_ID. Get it from:
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
# Make sure http://localhost:3000 is in Authorized JavaScript origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
